# ─── Sanity CMS ────────────────────────────────────────────────────────────────
# Get from: https://sanity.io/manage → your project → API
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production

# Read token — used for server-side draft fetching
# Create at: sanity.io/manage → API → Tokens → Add API token (Viewer)
SANITY_API_TOKEN=your_token_here

# Webhook secret — used to verify Sanity webhook requests for social publish
SANITY_WEBHOOK_SECRET=your_webhook_secret_here

# ─── Meta Graph API (Instagram + Facebook auto-publish) ────────────────────────
# Create at: developers.facebook.com
META_APP_ID=
META_APP_SECRET=

# Facebook Page ID (libraryxwar)
META_FB_PAGE_ID=
# Long-lived Page Access Token
META_FB_PAGE_ACCESS_TOKEN=

# Instagram Business Account ID (libraryofwar)
META_IG_USER_ID=

# ─── Contributor Portal ─────────────────────────────────────────────────────────
# Shared password for the /contributor page
CONTRIBUTOR_PASSWORD=your_shared_password_here

# Sanity write token — needs Editor or Administrator role
# Create at: sanity.io/manage → API → Tokens → Add API token (Editor)
SANITY_WRITE_TOKEN=your_write_token_here

# Resend API key — for email alerts when a draft is submitted
# Sign up at: resend.com (free tier: 3,000 emails/month)
# Must verify libraryofwar.com as a sending domain first
RESEND_API_KEY=re_your_key_here

# ─── Site ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://libraryofwar.com

# ─── Supabase — Hallowed Ground ────────────────────────────────────────────────
# Create project at: supabase.com → New Project
# Get URL + anon key from: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Import secret — used by scripts/import-soldiers.mjs to authenticate bulk inserts.
# The script calls the bulk_import_soldiers() RPC which checks this against a bcrypt hash.
# No service role key needed — the anon key + this secret is sufficient.
# Rotate by running in Supabase SQL Editor:
#   UPDATE _import_config SET value = crypt('new-secret', gen_salt('bf')) WHERE key = 'import_secret_hash';
SUPABASE_IMPORT_SECRET=your-import-secret-here

# ─── Stadia Maps (optional for localhost, required for production) ──────────────
# Register at: client.stadiamaps.com → API Keys
# Tiles work without a key on localhost. Required on Cloudflare Pages.
NEXT_PUBLIC_STADIA_API_KEY=your-stadia-key-here
